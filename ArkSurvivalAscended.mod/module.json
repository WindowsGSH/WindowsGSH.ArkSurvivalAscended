{
  "id": "ark-survival-ascended",
  "name": "Ark Survival Ascended Dedicated Server",
  "version": "1.24",
  "author": "Shenniko",
  "description": "WindowsGSH module for installing, configuring, launching, and backing up an ARK: Survival Ascended dedicated server.",
  "url": "https://github.com/WindowsGSH/WindowsGSH.ArkSurvivalAscended",
  "homepage": "https://ark.wiki.gg/wiki/Dedicated_server_setup",
  "repository": "https://github.com/WindowsGSH/WindowsGSH.ArkSurvivalAscended",
  "sourceUrl": "https://github.com/WindowsGSH/WindowsGSH.ArkSurvivalAscended",
  "color": "#1E8449",
  "moduleApiVersion": "1.0",
  "minimumWindowsGshVersion": "0.1.0",
  "type": "csharp",
  "entry": "WindowsGSH.Modules.ArkSurvivalAscended.ArkSurvivalAscendedModule",
  "platform": "windows",
  "source": "https://github.com/WindowsGSH/WindowsGSH.ArkSurvivalAscended",
  "steam": {
    "appId": "2430930",
    "anonymous": true,
    "validate": true
  },
  "entryPoints": {
    "start": "ShooterGame\\Binaries\\Win64\\ArkAscendedServer.exe",
    "processNames": [
      "ArkAscendedServer"
    ]
  },
  "runtime": {
    "allowsEmbeddedConsole": false,
    "consoleStrategy": "LogTailOnly",
    "portIncrements": 2,
    "queryProtocol": "process",
    "defaultArguments": "{server.map}?listen?SessionName={quote:server.name}?QueryPort={network.queryPort}?MaxPlayers={server.maxPlayers}{?rcon.enabled:?RCONEnabled=True?RCONPort={rcon.port}}{?cluster.enabled:{?cluster.altSaveDirectoryName:?AltSaveDirectoryName={cluster.altSaveDirectoryName}}} -MULTIHOME={network.ip} -port={network.port} {server.additionalArguments} -WinLiveMaxPlayers={server.maxPlayers}{?server.crossplay: -ServerPlatform=ALL}{?cluster.enabled: -clusterid={quote:cluster.id}{?cluster.directory: -ClusterDirOverride={quote:cluster.directory}}}",
    "logPath": "ShooterGame\\Saved\\Logs\\ShooterGame.log",
    "stop": {
      "strategy": "closeWindow",
      "waitMilliseconds": 2000,
      "killAfterTimeout": true
    }
  },
  "capabilities": {
    "directConnection": true
  },
  "import": {
    "windowsGsm": {
      "aliases": [
        "Ark Survival Ascended Dedicated Server",
        "WindowsGSM.ArkSurvivalAscended",
        "ArkSurvivalAscended"
      ],
      "installFolder": "serverfiles",
      "settings": {
        "servername": "server.name",
        "serverip": "network.ip",
        "serverport": "network.port",
        "serverqueryport": "network.queryPort",
        "rconport": "rcon.port",
        "servermap": "server.map",
        "servermaxplayer": "server.maxPlayers",
        "serverparam": "server.additionalArguments",
        "rconpassword": "rcon.password",
        "gslt": "steam.gslt"
      }
    }
  },
  "configFields": [
    {
      "key": "server.name",
      "label": "Server Name",
      "type": "Text",
      "defaultValue": "Ark Survival Ascended Dedicated Server",
