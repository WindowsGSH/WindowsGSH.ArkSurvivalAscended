      "group": "Server",
      "restartRequired": true
    },
    {
      "key": "network.ip",
      "label": "Server IP",
      "type": "Text",
      "defaultValue": "0.0.0.0",
      "group": "Network",
      "restartRequired": true
    },
    {
      "key": "network.port",
      "label": "Server Port",
      "type": "Port",
      "defaultValue": 7777,
      "required": true,
      "minimum": 1,
      "maximum": 65535,
      "group": "Network",
